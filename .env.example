# Copy this to .env and fill in your values. Never commit .env.

TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
GEMINI_API_KEY=your-gemini-api-key-here

# Your personal Telegram chat ID. The bot will ignore everyone else.
# Find it by messaging @userinfobot on Telegram.
ALLOWED_CHAT_ID=123456789

# Optional overrides (defaults shown)
# GEMINI_FAST_MODEL=gemini-2.5-flash-lite-preview-06-17
# GEMINI_STRONG_MODEL=gemini-2.5-pro
# DB_PATH=data/assistant.db
